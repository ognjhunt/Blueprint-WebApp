# Service account configuration for server-side Firebase Admin access.
# Provide either the JSON stringified credentials or a path to the key file.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# On Cloud Run / Cloud Functions you can also rely on the attached service account.

# Google Maps API key for Places autocomplete in the Capture page dialog
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google OAuth and Picker configuration (required for Google Drive picker)
# VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# VITE_GOOGLE_APP_ID=your_google_cloud_project_number

# Public web origin used for generated links in client flows
# VITE_PUBLIC_APP_URL=https://www.tryblueprint.io

# Stable mobile access URL used for capturer QR codes and handoff flows
# VITE_CAPTURE_APP_PLACEHOLDER_URL=https://www.tryblueprint.io/capture-app

# Waitlist automation worker for capturer beta triage
# BLUEPRINT_WAITLIST_AUTOMATION_ENABLED=true
# BLUEPRINT_WAITLIST_AUTOMATION_INTERVAL_MS=300000
# BLUEPRINT_WAITLIST_AUTOMATION_BATCH_SIZE=10
# BLUEPRINT_WAITLIST_AUTOMATION_STARTUP_DELAY_MS=15000

# Browser analytics for live measurement.
# Set these explicitly for production analytics and hosted verification.
VITE_GA_MEASUREMENT_ID=
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=
# Optional for local development.
VITE_ENABLE_ANALYTICS=true

# Sentry browser SDK DSN for error tracking
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Enable the error tracking smoke test helper (optional)
# VITE_ENABLE_ERROR_TRACKING_SMOKE_TEST=true

# Stripe API keys for checkout integration
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_CONNECT_ACCOUNT_ID=acct_your_stripe_connect_account_id
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# CHECKOUT_ALLOWED_ORIGINS=https://www.tryblueprint.io,https://tryblueprint.io

# Optional Stripe onboarding URLs (defaults to tryblueprint.io with standard paths)
# STRIPE_PUBLIC_BASE_URL=https://www.tryblueprint.io
# STRIPE_ONBOARDING_REFRESH_URL=https://www.tryblueprint.io/stripe/onboarding/refresh
# STRIPE_ONBOARDING_RETURN_URL=https://www.tryblueprint.io/stripe/onboarding/return

# Paperclip ops relays
# The production webapp can expose stable relay endpoints on tryblueprint.io while
# forwarding internally to a live local Paperclip instance.
# PAPERCLIP_OPS_STRIPE_WEBHOOK_URL=https://<paperclip-tunnel>.trycloudflare.com/api/plugins/blueprint.automation/webhooks/ops-stripe
# PAPERCLIP_OPS_FIRESTORE_WEBHOOK_URL=https://<paperclip-tunnel>.trycloudflare.com/api/plugins/blueprint.automation/webhooks/ops-firestore
# PAPERCLIP_OPS_FIRESTORE_RELAY_SECRET=replace_with_shared_secret

# Hosted demo runtime override for the static media-room walkthrough.
# Demo fixtures are disabled by default in production. Enable them explicitly
# when you need an internal-only demo world.
# VITE_ENABLE_DEMO_SITE_WORLDS=1
# BLUEPRINT_ENABLE_DEMO_SITE_WORLDS=1
# BLUEPRINT_DEMO_BUNDLE_PIPELINE_ROOT=/absolute/path/to/local/demo/pipeline
#
# Set these when you have a live NeoVerse runtime handle for SW-DEMO-01.
# BLUEPRINT_HOSTED_DEMO_RUNTIME_BASE_URL=https://your-live-runtime.example.com
# BLUEPRINT_HOSTED_DEMO_RUNTIME_WEBSOCKET_BASE_URL=wss://your-live-runtime.example.com

# World Labs Marble integration for site-specific interactive previews.
# WORLDLABS_API_KEY=your_worldlabs_api_key
# WORLDLABS_API_BASE_URL=https://api.worldlabs.ai
# WORLDLABS_DEFAULT_MODEL=Marble 0.1-mini

# Redis URL for hosted-session live state.
# For Upstash, use the TLS connection string from the Connect panel:
# REDIS_URL=rediss://default:<token>@active-phoenix-39183.upstash.io:6379
# Optional: set RATE_LIMIT_REDIS_URL separately if you want a dedicated Redis for rate limiting.

# Internal shared-secret auth.
# PIPELINE_SYNC_TOKEN=replace_me
# BLUEPRINT_REQUEST_REVIEW_TOKEN_SECRET=replace_me
# BLUEPRINT_ALPHA_OPERATIONS_ORIGIN=Blueprint field ops hub
# BLUEPRINT_EMAIL_DELIVERY_REQUIRED=1
# BLUEPRINT_PIPELINE_SYNC_REQUIRED=1

# OpenAI agent runtime for alpha automation.
# Required:
# OPENAI_API_KEY=sk-...
# Optional:
# OPENAI_DEFAULT_MODEL=gpt-5.4
# OPENAI_WAITLIST_AUTOMATION_MODEL=gpt-5.4
# OPENAI_INBOUND_QUALIFICATION_MODEL=gpt-5.4
# OPENAI_POST_SIGNUP_MODEL=gpt-5.4
# OPENAI_OPERATOR_THREAD_MODEL=gpt-5.4
# OPENAI_SUPPORT_TRIAGE_MODEL=gpt-5.4
# OPENAI_PAYOUT_EXCEPTION_MODEL=gpt-5.4
# OPENAI_PREVIEW_DIAGNOSIS_MODEL=gpt-5.4

# Direct Google integrations for post-signup workflows.
# Reuse the Firebase service account when possible via:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# or GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Alternatively set:
# GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CALENDAR_ID=your-ops-calendar@group.calendar.google.com
# POST_SIGNUP_SPREADSHEET_ID=your-google-sheet-id
# POST_SIGNUP_SHEET_NAME=Inbound (Website)

# Background automation workers.
# BLUEPRINT_WAITLIST_AUTOMATION_ENABLED=1
# BLUEPRINT_WAITLIST_AUTOMATION_INTERVAL_MS=300000
# BLUEPRINT_WAITLIST_AUTOMATION_BATCH_SIZE=10
# BLUEPRINT_INBOUND_AUTOMATION_ENABLED=1
# BLUEPRINT_INBOUND_AUTOMATION_INTERVAL_MS=300000
# BLUEPRINT_INBOUND_AUTOMATION_BATCH_SIZE=10
# BLUEPRINT_SUPPORT_TRIAGE_ENABLED=1
# BLUEPRINT_SUPPORT_TRIAGE_INTERVAL_MS=300000
# BLUEPRINT_SUPPORT_TRIAGE_BATCH_SIZE=10
# BLUEPRINT_PAYOUT_TRIAGE_ENABLED=1
# BLUEPRINT_PAYOUT_TRIAGE_INTERVAL_MS=600000
# BLUEPRINT_PAYOUT_TRIAGE_BATCH_SIZE=10
# BLUEPRINT_PREVIEW_DIAGNOSIS_ENABLED=1
# BLUEPRINT_PREVIEW_DIAGNOSIS_INTERVAL_MS=300000
# BLUEPRINT_PREVIEW_DIAGNOSIS_BATCH_SIZE=10

# Embeddings remain separate from OpenClaw for Blueprint knowledge indexing.
# OPENAI_API_KEY=sk-...
