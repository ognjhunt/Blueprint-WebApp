# Blueprint-WebApp launch environment template
#
# Copy the keys you need into your real deployment environment.
# Do not commit real secrets to source control.
#
# This file is organized around the autonomous alpha launch gate:
# - `npm run alpha:preflight`
# - `npm run smoke:agent`
# - `bash scripts/paperclip/verify-blueprint-paperclip.sh --smoke`

########################################
# Client build env
########################################

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional client integrations.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_APP_ID=
VITE_STRIPE_PUBLISHABLE_KEY=

########################################
# Core app + Firebase Admin
########################################

NODE_ENV=production
PORT=5000
VITE_PUBLIC_APP_URL=https://www.tryblueprint.io

# Optional stable mobile handoff URL.
VITE_CAPTURE_APP_PLACEHOLDER_URL=https://www.tryblueprint.io/capture-app

# Required for production Firebase Admin access.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative to FIREBASE_SERVICE_ACCOUNT_JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
FIELD_ENCRYPTION_MASTER_KEY=
# Or use a KMS-wrapped data-key path instead:
FIELD_ENCRYPTION_KMS_KEY_NAME=

########################################
# Structured agent runtime
########################################

# Configure at least one provider.
#
# Preferred on the trusted host: local Codex OAuth via the `codex` CLI.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ACP_HARNESS_URL=
ACP_HARNESS_TOKEN=

# Optional provider selection and model overrides.
BLUEPRINT_STRUCTURED_AUTOMATION_PROVIDER=
BLUEPRINT_STRUCTURED_AUTOMATION_FALLBACK_PROVIDER=
# Preflight mode:
# - strict: production/default behavior, waivers ignored
# - local_test: allow explicit waivers for local testing
BLUEPRINT_ALPHA_PREFLIGHT_MODE=strict
# Local testing only: waive specific preflight requirements without faking creds.
# Supported values: stripe, post_signup, research_outbound
BLUEPRINT_ALPHA_PREFLIGHT_WAIVERS=
CODEX_DEFAULT_MODEL=
OPENAI_DEFAULT_MODEL=
ANTHROPIC_DEFAULT_MODEL=
ACP_DEFAULT_HARNESS=

########################################
# Stripe checkout + payouts
########################################

STRIPE_SECRET_KEY=
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_ALLOWED_ORIGINS=https://www.tryblueprint.io

# Optional Stripe URLs.
STRIPE_PUBLIC_BASE_URL=
STRIPE_ONBOARDING_REFRESH_URL=
STRIPE_ONBOARDING_RETURN_URL=

########################################
# Pipeline + internal marketplace
########################################

PIPELINE_SYNC_TOKEN=
BLUEPRINT_REQUEST_REVIEW_TOKEN_SECRET=

########################################
# Autonomous alpha lane enables
########################################

BLUEPRINT_WAITLIST_AUTOMATION_ENABLED=1
BLUEPRINT_INBOUND_AUTOMATION_ENABLED=1
BLUEPRINT_SUPPORT_TRIAGE_ENABLED=1
BLUEPRINT_PAYOUT_TRIAGE_ENABLED=1
BLUEPRINT_PREVIEW_DIAGNOSIS_ENABLED=1
BLUEPRINT_EXPERIMENT_AUTOROLLOUT_ENABLED=1
BLUEPRINT_AUTONOMOUS_RESEARCH_OUTBOUND_ENABLED=1
BLUEPRINT_CREATIVE_FACTORY_ENABLED=1
BLUEPRINT_BUYER_LIFECYCLE_ENABLED=1

# Optional watchdogs.
BLUEPRINT_SITE_ACCESS_OVERDUE_WATCHDOG_ENABLED=1
BLUEPRINT_FINANCE_REVIEW_OVERDUE_WATCHDOG_ENABLED=1
BLUEPRINT_CAPTURER_REMINDER_ENABLED=1

########################################
# Gap closure registry (detect → delegate → escalate → auto-resolve)
########################################
#
# When enabled, periodically merges launch-readiness blockers + automation worker failures
# into Firestore `opsWorkItems`, notifies Slack (and optional webhook), escalates stale rows,
# and auto-completes items when readiness/worker signals clear. External gaps (CI, manual)
# post to /api/internal/gap-intake/report with X-Blueprint-Gap-Token.
#
BLUEPRINT_GAP_CLOSURE_ENABLED=1
# Default worker cadence is 15 minutes in code; override in ms if needed.
# BLUEPRINT_GAP_CLOSURE_INTERVAL_MS=900000
# BLUEPRINT_GAP_CLOSURE_BATCH_SIZE=100

BLUEPRINT_GAP_INTAKE_TOKEN=
# Optional: receives { event: "gap.delegated" | "gap.escalated", ... } JSON payloads.
BLUEPRINT_GAP_DELEGATION_WEBHOOK_URL=

########################################
# Post-signup automation
########################################

# Required unless you reuse FIREBASE_SERVICE_ACCOUNT_JSON / GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
POST_SIGNUP_SPREADSHEET_ID=
# Alternative legacy sheet key:
# SPREADSHEET_ID=

SLACK_WEBHOOK_URL=

########################################
# Email delivery
########################################

# Preferred first-party delivery path.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Blueprint
SENDGRID_EVENT_WEBHOOK_SECRET=

# Human blocker reply ingest and mailbox watcher.
BLUEPRINT_HUMAN_REPLY_INGEST_TOKEN=
BLUEPRINT_HUMAN_REPLY_APPROVED_EMAIL=ohstnhunt@gmail.com
BLUEPRINT_HUMAN_REPLY_GMAIL_CLIENT_ID=
BLUEPRINT_HUMAN_REPLY_GMAIL_CLIENT_SECRET=
BLUEPRINT_HUMAN_REPLY_GMAIL_REFRESH_TOKEN=
# Manual mirror of the Google OAuth consent-screen publishing state.
# Allowed values: testing, production. Leave unset to fail closed as unknown.
BLUEPRINT_HUMAN_REPLY_GMAIL_OAUTH_PUBLISHING_STATUS=
BLUEPRINT_HUMAN_REPLY_GMAIL_QUERY=newer_than:14d
BLUEPRINT_HUMAN_REPLY_GMAIL_WATCHER_ENABLED=0
# Slack reply watching is resumable only for surfaces the bot can actually see.
# Enable DMs and/or list allowed channel ids for thread replies.
BLUEPRINT_HUMAN_REPLY_SLACK_ALLOW_DMS=0
BLUEPRINT_HUMAN_REPLY_SLACK_ALLOWED_CHANNELS=
# Optional overrides:
# BLUEPRINT_HUMAN_REPLY_GMAIL_WATCHER_INTERVAL_MS=300000
# BLUEPRINT_HUMAN_REPLY_GMAIL_WATCHER_BATCH_SIZE=25
# BLUEPRINT_HUMAN_REPLY_GMAIL_WATCHER_STARTUP_DELAY_MS=100000

# Alternative SMTP path.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

########################################
# Growth event ingest + experiment rollout
########################################

BLUEPRINT_ANALYTICS_INGEST_ENABLED=1
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=
VITE_GA_MEASUREMENT_ID=

########################################
# Autonomous research outbound
########################################

FIREHOSE_API_TOKEN=
FIREHOSE_BASE_URL=
BLUEPRINT_AUTONOMOUS_RESEARCH_TOPICS=robot-teams,site-operators,capturer-supply

# Choose one delivery path: sendgrid or nitrosend.
BLUEPRINT_AUTONOMOUS_OUTBOUND_CHANNEL=sendgrid
BLUEPRINT_AUTONOMOUS_OUTBOUND_RECIPIENTS=

NITROSEND_API_KEY=
NITROSEND_BASE_URL=
BLUEPRINT_AUTONOMOUS_NITROSEND_AUDIENCE_ID=

########################################
# Creative factory
########################################

GOOGLE_GENAI_API_KEY=
# Alternative accepted key:
# GEMINI_API_KEY=
GOOGLE_CREATIVE_IMAGE_MODEL=
GOOGLE_CREATIVE_IMAGE_DEFAULT_ASPECT_RATIO=

RUNWAY_API_KEY=
RUNWAY_BASE_URL=
BLUEPRINT_RUNWAY_VIDEO_MODEL=

########################################
# Buyer lifecycle + voice concierge
########################################

BLUEPRINT_VOICE_BOOKING_URL=
BLUEPRINT_SUPPORT_EMAIL=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL_ID=
ELEVENLABS_AGENT_ID=
ELEVENLABS_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
BLUEPRINT_VOICE_FORWARD_NUMBER=

########################################
# Hosted sessions, rate limiting, and monitoring
########################################

REDIS_URL=
RATE_LIMIT_REDIS_URL=

VITE_SENTRY_DSN=
VITE_ENABLE_ERROR_TRACKING_SMOKE_TEST=false

########################################
# Paperclip relays from Blueprint-WebApp to the local/shared hub
########################################

PAPERCLIP_OPS_STRIPE_WEBHOOK_URL=
PAPERCLIP_OPS_FIRESTORE_WEBHOOK_URL=
PAPERCLIP_OPS_FIRESTORE_RELAY_SECRET=

########################################
# Notion sync
########################################

NOTION_API_KEY=
NOTION_CAMPAIGNS_DB_ID=
NOTION_CREATIVE_RUNS_DB_ID=
NOTION_GRADUATION_DB_ID=
NOTION_SLA_DB_ID=
NOTION_TASKS_DB_ID=

########################################
# Paperclip model fallback config (Hermes primary, Codex for coding)
########################################

# Hermes primary model (free OpenRouter) - used by ops/growth agents
# Example: qwen/qwen3.6-plus:free
BLUEPRINT_PAPERCLIP_HERMES_MODEL=

# Fallback ladder for Hermes when primary hits quota (tried in order)
# Comma-separated list of free OpenRouter models
# BLUEPRINT_PAPERCLIP_HERMES_FALLBACK_MODELS=qwen/qwen3.6-plus:free,openrouter/free,stepfun/step-3.5-flash:free,nvidia/nemotron-3-super:free

# Single fallback model (simpler alternative)
# BLUEPRINT_PAPERCLIP_HERMES_FALLBACK_MODEL=qwen/qwen3.6-plus:free

# Phase 2 action execution (enable waitlist lane for autonomous execution)
# BLUEPRINT_PHASE2_WAITLIST_ENABLED=1
