{
  "companyName": "Blueprint Autonomous Operations",
  "githubOwner": "ognjhunt",
  "enableGitRepoScanning": true,
  "enableGithubPolling": true,
  "enableOutboundNotifications": true,
  "repoCatalog": [
    {
      "key": "webapp",
      "projectName": "blueprint-webapp",
      "githubRepo": "Blueprint-WebApp",
      "defaultBranch": "main",
      "implementationAgent": "webapp-codex",
      "reviewAgent": "webapp-review"
    },
    {
      "key": "pipeline",
      "projectName": "blueprint-capture-pipeline",
      "githubRepo": "BlueprintCapturePipeline",
      "defaultBranch": "main",
      "implementationAgent": "pipeline-codex",
      "reviewAgent": "pipeline-review"
    },
    {
      "key": "capture",
      "projectName": "blueprint-capture",
      "githubRepo": "BlueprintCapture",
      "defaultBranch": "main",
      "implementationAgent": "capture-codex",
      "reviewAgent": "capture-review"
    }
  ],
  "opsDepartment": {
    "enabled": true,
    "agents": {
      "opsLead": "ops-lead",
      "intake": "intake-agent",
      "captureQa": "capture-qa-agent",
      "fieldOps": "field-ops-agent",
      "financeSupport": "finance-support-agent"
    }
  },
  "growthDepartment": {
    "enabled": true,
    "agents": {
      "growthLead": "growth-lead",
      "conversionOptimizer": "conversion-agent",
      "analytics": "analytics-agent",
      "communityUpdates": "community-updates-agent",
      "marketIntel": "market-intel-agent",
      "demandIntel": "demand-intel-agent",
      "robotTeamGrowth": "robot-team-growth-agent",
      "siteOperatorPartnership": "site-operator-partnership-agent",
      "cityDemand": "city-demand-agent"
    }
  },
  "management": {
    "chiefOfStaffAgent": "blueprint-chief-of-staff"
  },
  "secrets": {
    "notionApiTokenRef": "NOTION_API_TOKEN",
    "slackOpsWebhookUrlRef": "SLACK_OPS_WEBHOOK_URL",
    "slackGrowthWebhookUrlRef": "SLACK_GROWTH_WEBHOOK_URL",
    "slackExecWebhookUrlRef": "SLACK_EXEC_WEBHOOK_URL",
    "slackEngineeringWebhookUrlRef": "SLACK_ENGINEERING_WEBHOOK_URL",
    "slackManagerWebhookUrlRef": "SLACK_MANAGER_WEBHOOK_URL",
    "searchApiKeyRef": "SEARCH_API_KEY",
    "searchApiProviderRef": "SEARCH_API_PROVIDER",
    "firehoseApiTokenRef": "FIREHOSE_API_TOKEN",
    "introwApiTokenRef": "INTROW_API_TOKEN",
    "stripeSecretKeyRef": "STRIPE_SECRET_KEY",
    "stripeConnectAccountIdRef": "STRIPE_CONNECT_ACCOUNT_ID",
    "stripeWebhookSecretRef": "STRIPE_WEBHOOK_SECRET"
  },
  "marketingCapabilities": {
    "firehoseBaseUrl": "https://marketing.example.com/firehose",
    "introwBaseUrl": "https://marketing.example.com/introw",
    "firehoseDefaultTopics": [
      "robot-teams",
      "site-operators",
      "capturer-supply"
    ],
    "firehoseMaxSignalsPerRead": 20,
    "introwDefaultWorkspace": "blueprint"
  }
}
