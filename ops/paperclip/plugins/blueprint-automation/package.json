{
  "name": "@blueprint/plugin-automation",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Blueprint-specific Paperclip automation plugin",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
