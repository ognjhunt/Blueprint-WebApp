# Copy this file to /Users/nijelhunt_1/workspace/.paperclip-blueprint.env
# and fill in the values that apply to your host. Bootstrap, verify, smoke,
# and the LaunchAgent all read from that central file when present.

PAPERCLIP_PORT=3100
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_PUBLIC_URL=http://127.0.0.1:3100

# Recommended for the shared launchd-backed instance. If unset, Paperclip falls back
# to embedded PostgreSQL, which has been a source of restart and lockfile churn.
DATABASE_URL=
BLUEPRINT_PAPERCLIP_REQUIRE_EXTERNAL_POSTGRES=1
COMPANY_NAME="Blueprint Autonomous Operations"
# Optional but recommended when more than one Blueprint company exists in the same Paperclip instance.
# Pinning the company id prevents the automation harness and Slack alerts from attaching to the wrong org.
BLUEPRINT_PAPERCLIP_COMPANY_ID=
BLUEPRINT_PAPERCLIP_VERIFY_CLAUDE=1
BLUEPRINT_PAPERCLIP_AUTO_SETUP_GITHUB_WEBHOOKS=1
BLUEPRINT_PAPERCLIP_ENABLE_CLOUDFLARED_TUNNEL=1

# Claude/Codex lane control for executive and review agents.
# - auto: prefer Claude when adapter probes pass, otherwise fail over to Codex
# - claude: force Claude for those lanes
# - codex: force Codex for those lanes
#
# The LaunchAgent maintenance loop re-runs bootstrap/reconcile every few minutes,
# so auto mode can return the lanes to Claude when it becomes healthy again.
BLUEPRINT_PAPERCLIP_CLAUDE_LANE_MODE=auto

# Legacy compatibility flag. New installs should use BLUEPRINT_PAPERCLIP_CLAUDE_LANE_MODE.
BLUEPRINT_PAPERCLIP_FORCE_CODEX_CLAUDE_LANES=0
BLUEPRINT_PAPERCLIP_CLAUDE_LANE_FALLBACK_MODEL=gpt-5.4
BLUEPRINT_PAPERCLIP_CLAUDE_LANE_FALLBACK_REASONING_EFFORT=high

# Optional but recommended for GitHub workflow polling and webhook verification.
BLUEPRINT_PAPERCLIP_GITHUB_OWNER=ognjhunt
BLUEPRINT_PAPERCLIP_GITHUB_TOKEN=
BLUEPRINT_PAPERCLIP_GITHUB_WEBHOOK_SECRET=

# Optional shared secrets for the generic CI and operator-intake webhook paths.
BLUEPRINT_PAPERCLIP_CI_SHARED_SECRET=
BLUEPRINT_PAPERCLIP_INTAKE_SHARED_SECRET=

# Optional Stripe runtime secrets used by the Paperclip plugin and host runtime.
STRIPE_SECRET_KEY=
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_WEBHOOK_SECRET=

# Optional outbound notification target.
BLUEPRINT_PAPERCLIP_NOTIFICATION_WEBHOOK_URL=

# Notion API (for agent Work Queue and Knowledge DB access)
NOTION_API_TOKEN=secret_...

# Slack Webhooks (for agent digests and alerts)
SLACK_OPS_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_GROWTH_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_EXEC_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_ENGINEERING_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_MANAGER_WEBHOOK_URL=https://hooks.slack.com/services/...

# Web Search API (for approved research and fact-check agents)
# parallel_mcp uses the free Parallel Search MCP endpoint without a key.
# Set PARALLEL_API_KEY only when you want authenticated Parallel usage.
# Keep SEARCH_API_KEY for non-Parallel providers such as Brave or Perplexity.
SEARCH_API_PROVIDER=parallel_mcp  # or brave, perplexity
SEARCH_API_KEY=
PARALLEL_API_KEY=

# Optional Deep Research MCP config. Use the city-specific var for city-launch-only runs.
BLUEPRINT_DEEP_RESEARCH_MCP_SERVERS_JSON='[{"name":"parallel-search","url":"https://search.parallel.ai/mcp","allowed_tools":{"mode":"validated","tools":["web_search","web_fetch"]}}]'
BLUEPRINT_CITY_LAUNCH_DEEP_RESEARCH_MCP_SERVERS_JSON=

# Hermès DeepSeek model ladder.
# Hermes uses DeepSeek's Anthropic-compatible endpoint on this host because the
# installed Hermes CLI accepts `--provider anthropic`; structured WebApp agents
# use the OpenAI-compatible `https://api.deepseek.com` endpoint directly.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_REASONING_EFFORT=max
DEEPSEEK_THINKING=enabled
# If structured agents use DeepSeek through OpenRouter, prefer low cache-read endpoints.
DEEPSEEK_OPENROUTER_PROVIDER_ONLY=deepseek,atlas-cloud/fp8,novita,siliconflow/fp8
DEEPSEEK_OPENROUTER_PROVIDER_ORDER=deepseek,atlas-cloud/fp8,novita,siliconflow/fp8
DEEPSEEK_OPENROUTER_PROVIDER_IGNORE=parasail,parasail/fp8,akashml,akashml/fp8,deepinfra,deepinfra/fp4
DEEPSEEK_OPENROUTER_ALLOW_FALLBACKS=1
# Optional managed-runtime spend guardrails. Leave unset to observe only.
BLUEPRINT_AGENT_COST_WARN_15M_USD=
BLUEPRINT_AGENT_COST_WARN_HOUR_USD=
BLUEPRINT_AGENT_COST_WARN_DAY_USD=
BLUEPRINT_AGENT_COST_STOP_15M_USD=
BLUEPRINT_AGENT_COST_STOP_HOUR_USD=
BLUEPRINT_AGENT_COST_STOP_DAY_USD=
# Chief-of-Staff wake dedupe/backoff controls for event bursts.
BLUEPRINT_CHIEF_OF_STAFF_WAKE_TTL_MS=900000
BLUEPRINT_CHIEF_OF_STAFF_WAKE_BACKOFF_MS=60000
BLUEPRINT_CHIEF_OF_STAFF_WAKE_MAX_ATTEMPTS=3
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max
BLUEPRINT_PAPERCLIP_HERMES_ALLOW_PAID_MODELS=0
BLUEPRINT_PAPERCLIP_HERMES_PROVIDER=anthropic
BLUEPRINT_PAPERCLIP_HERMES_BASE_URL=https://api.deepseek.com/anthropic
BLUEPRINT_PAPERCLIP_HERMES_PRIMARY_MODEL=deepseek-v4-flash
BLUEPRINT_PAPERCLIP_HERMES_FALLBACK_MODEL=deepseek-v4-pro[1m]
BLUEPRINT_PAPERCLIP_HERMES_FALLBACK_MODELS=deepseek-v4-flash,deepseek-v4-pro[1m]
BLUEPRINT_PAPERCLIP_HERMES_INCLUDE_OPENROUTER_FALLBACKS=0

# Legacy text fallback only. Keep available, but do not opt in unless DeepSeek
# routing is intentionally rolled back.
OPENROUTER_API_KEY=
# BLUEPRINT_PAPERCLIP_HERMES_INCLUDE_OPENROUTER_FALLBACKS=1
BLUEPRINT_PAPERCLIP_HERMES_OPENROUTER_PROVIDER_ONLY=deepseek,atlas-cloud/fp8,novita,siliconflow/fp8
BLUEPRINT_PAPERCLIP_HERMES_OPENROUTER_PROVIDER_ORDER=deepseek,atlas-cloud/fp8,novita,siliconflow/fp8
BLUEPRINT_PAPERCLIP_HERMES_OPENROUTER_PROVIDER_IGNORE=parasail,parasail/fp8,akashml,akashml/fp8,deepinfra,deepinfra/fp4
BLUEPRINT_PAPERCLIP_HERMES_OPENROUTER_ALLOW_FALLBACKS=1

# OpenCode tertiary fallback should also stay free-only unless you explicitly opt out.
BLUEPRINT_PAPERCLIP_OPENCODE_ALLOW_PAID_MODELS=0
BLUEPRINT_PAPERCLIP_OPENCODE_PRIMARY_MODEL=minimax/minimax-m2.5:free
BLUEPRINT_PAPERCLIP_OPENCODE_FALLBACK_MODEL=openrouter/qwen/qwen3-coder-480b:free

# Blueprint-owned marketing integration adapters
VITE_GA_MEASUREMENT_ID=
FIREHOSE_API_TOKEN=
FIREHOSE_BASE_URL=https://marketing.example.com/firehose
INTROW_API_TOKEN=
BLUEPRINT_PAPERCLIP_FIREHOSE_BASE_URL=https://marketing.example.com/firehose
BLUEPRINT_PAPERCLIP_INTROW_BASE_URL=https://marketing.example.com/introw
BLUEPRINT_PAPERCLIP_FIREHOSE_DEFAULT_TOPICS=robot-teams,site-operators,capturer-supply
BLUEPRINT_PAPERCLIP_FIREHOSE_MAX_SIGNALS_PER_READ=20
BLUEPRINT_PAPERCLIP_INTROW_DEFAULT_WORKSPACE=blueprint
