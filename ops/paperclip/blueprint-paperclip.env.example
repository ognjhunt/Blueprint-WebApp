# Copy this file to /Users/nijelhunt_1/workspace/.paperclip-blueprint.env
# and fill in the values that apply to your host. Bootstrap, verify, smoke,
# and the LaunchAgent all read from that central file when present.

PAPERCLIP_PUBLIC_URL=http://127.0.0.1:3100
COMPANY_NAME=Blueprint Autonomous Operations

# Optional but recommended for GitHub workflow polling and webhook verification.
BLUEPRINT_PAPERCLIP_GITHUB_OWNER=ognjhunt
BLUEPRINT_PAPERCLIP_GITHUB_TOKEN=
BLUEPRINT_PAPERCLIP_GITHUB_WEBHOOK_SECRET=

# Optional shared secrets for the generic CI and operator-intake webhook paths.
BLUEPRINT_PAPERCLIP_CI_SHARED_SECRET=
BLUEPRINT_PAPERCLIP_INTAKE_SHARED_SECRET=
