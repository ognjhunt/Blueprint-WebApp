# Copy this file to /Users/nijelhunt_1/workspace/.paperclip-blueprint.env
# and fill in the values that apply to your host. Bootstrap, verify, smoke,
# and the LaunchAgent all read from that central file when present.

PAPERCLIP_API_URL=http://127.0.0.1:3101
PAPERCLIP_PUBLIC_URL=http://127.0.0.1:3101
COMPANY_NAME="Blueprint Autonomous Operations"
BLUEPRINT_PAPERCLIP_VERIFY_CLAUDE=1
BLUEPRINT_PAPERCLIP_AUTO_SETUP_GITHUB_WEBHOOKS=1
BLUEPRINT_PAPERCLIP_ENABLE_CLOUDFLARED_TUNNEL=1

# Claude/Codex lane control for executive and review agents.
# - auto: prefer Claude when adapter probes pass, otherwise fail over to Codex
# - claude: force Claude for those lanes
# - codex: force Codex for those lanes
#
# The LaunchAgent maintenance loop re-runs bootstrap/reconcile every few minutes,
# so auto mode can return the lanes to Claude when it becomes healthy again.
BLUEPRINT_PAPERCLIP_CLAUDE_LANE_MODE=auto

# Legacy compatibility flag. New installs should use BLUEPRINT_PAPERCLIP_CLAUDE_LANE_MODE.
BLUEPRINT_PAPERCLIP_FORCE_CODEX_CLAUDE_LANES=0
BLUEPRINT_PAPERCLIP_CLAUDE_LANE_FALLBACK_MODEL=gpt-5.4
BLUEPRINT_PAPERCLIP_CLAUDE_LANE_FALLBACK_REASONING_EFFORT=high

# Optional but recommended for GitHub workflow polling and webhook verification.
BLUEPRINT_PAPERCLIP_GITHUB_OWNER=ognjhunt
BLUEPRINT_PAPERCLIP_GITHUB_TOKEN=
BLUEPRINT_PAPERCLIP_GITHUB_WEBHOOK_SECRET=

# Optional shared secrets for the generic CI and operator-intake webhook paths.
BLUEPRINT_PAPERCLIP_CI_SHARED_SECRET=
BLUEPRINT_PAPERCLIP_INTAKE_SHARED_SECRET=

# Optional outbound notification target.
BLUEPRINT_PAPERCLIP_NOTIFICATION_WEBHOOK_URL=

# Notion API (for agent Work Queue and Knowledge DB access)
NOTION_API_TOKEN=secret_...

# Slack Webhooks (for agent digests and alerts)
SLACK_OPS_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_GROWTH_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_EXEC_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_ENGINEERING_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_MANAGER_WEBHOOK_URL=https://hooks.slack.com/services/...

# Web Search API (for Market Intel agent)
SEARCH_API_KEY=...
SEARCH_API_PROVIDER=tavily  # or serpapi, brave

# OpenCode fallback (free, auto-activates when paid providers fail)
# Uses opencode/minimax-m2.5-free (no API key needed)
OPENROUTER_API_KEY=
BLUEPRINT_PAPERCLIP_OPENCODE_PRIMARY_MODEL=opencode/minimax-m2.5-free
BLUEPRINT_PAPERCLIP_OPENCODE_FALLBACK_MODEL=opencode/minimax-m2.5-free

# Blueprint-owned marketing integration adapters
NITROSEND_API_TOKEN=
FIREHOSE_API_TOKEN=
INTROW_API_TOKEN=
BLUEPRINT_PAPERCLIP_NITROSEND_BASE_URL=https://marketing.example.com/nitrosend
BLUEPRINT_PAPERCLIP_FIREHOSE_BASE_URL=https://marketing.example.com/firehose
BLUEPRINT_PAPERCLIP_INTROW_BASE_URL=https://marketing.example.com/introw
BLUEPRINT_PAPERCLIP_FIREHOSE_DEFAULT_TOPICS=robot-teams,site-operators,capturer-supply
BLUEPRINT_PAPERCLIP_FIREHOSE_MAX_SIGNALS_PER_READ=20
BLUEPRINT_PAPERCLIP_INTROW_DEFAULT_WORKSPACE=blueprint
